## Final Models

```{r}
##############
# TOP MODELS #
##############

# OURS #
OurTopModel <- coxph(Surv(SizeChange, Status) ~ Fuel_type + FWI*logIA_Size + Month, data = wf_train, x = T)
OurTopModel %>% tbl_regression(exponentiate = T)

# PAPER #
PaperTopModel <- coxph(Surv(SizeChange, Status) ~ FWI + Method + Fuel_type, data = wf_train, x = T)
PaperTopModel %>% tbl_regression(exponentiate = T)
```

## Assumptions

```{r}
# OURS #
# proportional hazards
top_coxzph <- cox.zph(OurTopModel)
top_coxzph
top_coxzph %>% ggcoxzph
# multicolinearity
noint_topmodel <- coxph(Surv(SizeChange, Status) ~ Fuel_type + FWI + logIA_Size + Month, data = wf_train, x = T)
vif(noint_topmodel)
# linearity
OurTopModel %>% ggcoxdiagnostics()

# PAPER #
# proportional hazards
pap_coxzph <- cox.zph(PaperTopModel)
pap_coxzph
pap_coxzph %>% ggcoxzph
# multicolinearity
vif(PaperTopModel)
# linearity
PaperTopModel %>% ggcoxdiagnostics()
```

